.page{min-height:100vh;padding:28rpx;background:#f5fafd}.header{display:flex;align-items:center;justify-content:space-between}.title{color:#294755;font-size:32rpx;font-weight:700}.header text{display:block;margin-top:8rpx;color:#8ca1ab;font-size:19rpx}.clear{padding:10rpx 19rpx;border:1rpx solid #bed8e3;border-radius:24rpx;color:#568697;font-size:19rpx}.grid{margin-top:25rpx;display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:22rpx}.grid product-card{min-width:0}.empty{padding:100rpx 0;color:#607b87;text-align:center}.empty image{width:300rpx;height:250rpx}.empty view{font-size:27rpx;font-weight:600}.empty text{display:block;margin-top:10rpx;color:#9babb2;font-size:20rpx}.empty button{width:190rpx;height:68rpx;margin-top:25rpx;border-radius:34rpx;background:#2e99c6;color:#fff;font-size:22rpx;line-height:68rpx}.empty button::after{border:0}
