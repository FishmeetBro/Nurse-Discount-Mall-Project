.page { min-height: 100vh; background: #f5fafd; }
.product-visual { position:relative;height:570rpx;overflow:hidden;background:#edf8fc }
.visual-product-image{width:100%;height:100%}
.visual-circle { position: absolute; width: 410rpx; height: 410rpx; border-radius: 50%; background: rgba(255,255,255,.55); box-shadow: 0 20rpx 50rpx rgba(66,119,145,.08); }
.visual-product { position: relative; z-index: 1; width: 220rpx; height: 270rpx; display: flex; align-items: center; justify-content: center; border: 13rpx solid #fff; border-radius: 42rpx 42rpx 65rpx 65rpx; background: rgba(255,255,255,.75); color: #5ba2c2; font-size: 122rpx; box-shadow: 0 22rpx 45rpx rgba(62,117,143,.14); }
.visual-tag { position: absolute; left: 28rpx; top: 30rpx; padding: 10rpx 18rpx; border-radius: 20rpx; background: rgba(255,255,255,.82); color: #3d8db2; font-size: 21rpx; }
.visual-index { position: absolute; right: 27rpx; bottom: 25rpx; padding: 8rpx 17rpx; border-radius: 20rpx; background: rgba(51,78,91,.54); color: #fff; font-size: 20rpx; }
.main-card { position: relative; z-index: 2; margin-top: -18rpx; padding: 32rpx 30rpx 28rpx; border-radius: 30rpx 30rpx 0 0; background: #fff; }
.tag-row { display: flex; gap: 12rpx; }
.hot-tag, .quality-tag { padding: 6rpx 13rpx; border-radius: 7rpx; font-size: 19rpx; }
.hot-tag { background: #fff0ef; color: #ee6567; }
.quality-tag { background: #e8f7fd; color: #318db8; }
.product-name { margin-top: 18rpx; color: #203b49; font-size: 36rpx; font-weight: 700; line-height: 1.35; }
.product-feature { margin-top: 11rpx; color: #8ca1ac; font-size: 23rpx; }
.partner-price { margin-top: 30rpx; padding: 24rpx; display: flex; align-items: center; justify-content: space-between; border-radius: 20rpx; background: linear-gradient(100deg, #e9f7fe, #f5fbfe); }
.price-label { color: #317fa4; font-size: 22rpx; }
.price-label text { margin-left: 9rpx; padding: 4rpx 8rpx; border-radius: 6rpx; background: #48a8d1; color: #fff; font-size: 17rpx; }
.price { margin-top: 5rpx; color: #ed5c61; font-size: 48rpx; font-weight: 700; }
.price text { font-size: 25rpx; }
.saving { padding: 8rpx 14rpx; border-radius: 18rpx; background: #fff; color: #e36c6c; font-size: 20rpx; }
.normal-price-row { display: flex; align-items: center; margin-top: 21rpx; color: #8b9ca5; font-size: 21rpx; }
.normal-price { margin-left: 10rpx; color: #586e79; font-weight: 600; }
.sales { margin-left: auto; }
.service-row { padding: 24rpx 30rpx; display: flex; justify-content: space-between; border-top: 2rpx solid #f0f4f6; background: #fff; color: #69818d; font-size: 21rpx; }
.service-row text { color: #36aa82; }
.detail-card { margin-top: 20rpx; padding: 30rpx; background: #fff; }
.section-title { padding-left: 16rpx; border-left: 7rpx solid #4aa9d3; color: #294857; font-size: 30rpx; font-weight: 700; }
.license-box { margin-top: 26rpx; padding: 22rpx; display: flex; align-items: center; border-radius: 18rpx; background: #f1f9fc; }
.license-icon { flex: none; width: 72rpx; height: 72rpx; border-radius: 17rpx; background: #d9eff8; color: #308bb5; font-size: 30rpx; font-weight: 700; text-align: center; line-height: 72rpx; }
.license-content { flex: 1; min-width: 0; margin-left: 18rpx; }
.license-name { color: #385a6b; font-size: 24rpx; font-weight: 600; }
.license-number { margin-top: 7rpx; color: #879ca6; font-size: 19rpx; }
.license-status { color: #2fa67e; font-size: 20rpx; }
.qualification-list { margin-top: 12rpx; }
.qualification-list view { padding: 18rpx 5rpx; display: flex; justify-content: space-between; border-bottom: 2rpx solid #f1f4f5; color: #738994; font-size: 21rpx; }
.qualification-list view text:last-child { max-width: 470rpx; color: #405c69; text-align: right; }
.medical-warning { margin-top: 20rpx; padding: 20rpx; border-radius: 13rpx; background: #fff8ec; color: #9b7a47; font-size: 20rpx; line-height: 1.65; }
.highlight-list { margin-top: 23rpx; }
.highlight-list view { margin-top: 17rpx; color: #5c7480; font-size: 23rpx; }
.highlight-list text { display: inline-block; width: 39rpx; height: 39rpx; margin-right: 15rpx; border-radius: 50%; background: #e4f5fc; color: #3595bd; text-align: center; line-height: 39rpx; }
.compliance { margin: 20rpx 28rpx 0; padding: 24rpx; border-radius: 18rpx; background: #eaf2f5; color: #748a94; font-size: 20rpx; line-height: 1.65; }
.compliance-title { margin-bottom: 8rpx; color: #557684; font-weight: 700; }
.bottom-placeholder { height: 150rpx; }
.bottom-bar { position: fixed; z-index: 20; right: 0; bottom: 0; left: 0; min-height: 112rpx; padding: 14rpx 20rpx calc(14rpx + env(safe-area-inset-bottom)); box-sizing: border-box; display: flex; align-items: center; gap: 13rpx; background: #fff; box-shadow: 0 -8rpx 28rpx rgba(44,89,111,.1); }
.bar-tool { flex: none; width: 70rpx; padding: 0; border-radius: 0; background: transparent; color: #728994; font-size: 19rpx; text-align: center; line-height: 1.2; }
.bar-tool text { display: block; margin-bottom: 5rpx; color: #4c829a; font-size: 32rpx; }
.share-tool::after { border: 0; }
.poster-button, .cart-button { flex: 1; height: 76rpx; margin: 0; padding: 0 10rpx; border-radius: 38rpx; font-size: 23rpx; line-height: 76rpx; }
.poster-button { border: 2rpx solid #3ca3d1; background: #fff; color: #338fba; }
.cart-button { background: linear-gradient(90deg, #4db3de, #278fc5); color: #fff; }
.poster-mask { position: fixed; z-index: 100; top: 0; right: 0; bottom: 0; left: 0; display: flex; align-items: center; justify-content: center; background: rgba(21,44,55,.68); }
.poster-panel { position: relative; width: 650rpx; padding: 30rpx 30rpx 25rpx; box-sizing: border-box; border-radius: 28rpx; background: #fff; text-align: center; }
.poster-close { position: absolute; top: 14rpx; right: 18rpx; width: 58rpx; height: 58rpx; color: #8599a2; font-size: 44rpx; line-height: 54rpx; }
.poster-title { color: #294958; font-size: 31rpx; font-weight: 700; }
.poster-subtitle { margin-top: 7rpx; color: #91a3ac; font-size: 20rpx; }
.canvas-wrap { width: 450rpx; height: 720rpx; margin: 22rpx auto 18rpx; overflow: hidden; border-radius: 14rpx; box-shadow: 0 8rpx 28rpx rgba(44,87,107,.16); }
.poster-canvas { width: 450rpx; height: 720rpx; }
.save-button { width: 450rpx; height: 76rpx; border-radius: 38rpx; background: #319dcc; color: #fff; font-size: 25rpx; line-height: 76rpx; }
.poster-note { margin-top: 12rpx; color: #a1afb6; font-size: 18rpx; }
