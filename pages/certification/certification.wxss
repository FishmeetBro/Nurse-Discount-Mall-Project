.page { min-height: 100vh; padding-bottom: 40rpx; background: #f5fafd; }
.hero { position: relative; overflow: hidden; padding: 40rpx 28rpx 44rpx; text-align: center; background: linear-gradient(155deg, #e4f6ff 0%, #f7fcff 74%); }
.hero-decoration { position: absolute; color: #8dd0ef; opacity: .28; font-size: 70rpx; font-weight: 300; }
.cert-illustration{width:164rpx;height:164rpx;border:6rpx solid rgba(255,255,255,.86);border-radius:50%;box-shadow:0 12rpx 30rpx rgba(45,143,187,.16)}
.decoration-one { left: 52rpx; top: 44rpx; transform: rotate(18deg); }
.decoration-two { right: 58rpx; top: 92rpx; transform: rotate(-12deg); }
.shield { position: relative; width: 116rpx; height: 126rpx; margin: 0 auto; }
.shield-cap { position: absolute; z-index: 2; top: 0; left: 28rpx; width: 60rpx; height: 42rpx; border-radius: 22rpx 22rpx 8rpx 8rpx; background: #2d9fd3; color: #fff; font-size: 31rpx; line-height: 40rpx; }
.shield-body { position: absolute; left: 8rpx; bottom: 0; width: 100rpx; height: 100rpx; box-sizing: border-box; border: 7rpx solid #59b6df; border-radius: 28rpx 28rpx 52rpx 52rpx; background: #fff; color: #36a5d5; font-size: 50rpx; line-height: 88rpx; box-shadow: 0 12rpx 28rpx rgba(65, 161, 205, .16); }
.hero-title { margin-top: 15rpx; color: #24698b; font-size: 40rpx; font-weight: 700; }
.hero-desc { margin-top: 10rpx; color: #7897a7; font-size: 23rpx; }
.step-row { display: flex; align-items: flex-start; justify-content: center; margin-top: 38rpx; }
.step { width: 104rpx; color: #9db0b9; font-size: 19rpx; }
.step text { display: block; width: 42rpx; height: 42rpx; margin: 0 auto 9rpx; border-radius: 50%; background: #dce8ed; color: #8ba2ae; line-height: 42rpx; }
.step.active { color: #348aaf; }
.step.active text { background: #43a9d6; color: #fff; }
.step-line { width: 82rpx; height: 3rpx; margin-top: 20rpx; background: #dce8ed; }
.active-line { background: #66b8dc; }

.benefit-card, .form-card, .result-card { margin: 24rpx 28rpx 0; border-radius: 24rpx; background: #fff; box-shadow: 0 10rpx 30rpx rgba(52, 110, 139, .07); }
.benefit-card { padding: 25rpx 28rpx; }
.benefit-title { color: #31576a; font-size: 26rpx; font-weight: 700; }
.benefit-list { display: flex; justify-content: space-around; margin-top: 25rpx; }
.benefit-item { width: 31%; color: #647f8d; font-size: 21rpx; text-align: center; }
.benefit-icon { width: 64rpx; height: 64rpx; margin: 0 auto 12rpx; border-radius: 20rpx; background: #e8f7fd; color: #379ac6; font-size: 26rpx; font-weight: 700; line-height: 64rpx; }
.form-card { padding: 32rpx 28rpx; }
.card-title { color: #263f4d; font-size: 32rpx; font-weight: 700; }
.card-subtitle { margin-top: 8rpx; color: #9aabb4; font-size: 21rpx; }
.field { margin-top: 35rpx; }
.field-label { margin-bottom: 16rpx; color: #3a5665; font-size: 25rpx; font-weight: 600; }
.required { color: #f2696c; }
.input-wrap { height: 92rpx; padding: 0 22rpx; display: flex; align-items: center; border: 2rpx solid #dae8ef; border-radius: 17rpx; background: #f9fcfd; }
.input-wrap input { flex: 1; height: 92rpx; color: #304c5a; font-size: 27rpx; }
.placeholder { color: #b5c1c7; }
.clear { width: 50rpx; color: #a7b7bf; font-size: 37rpx; text-align: center; }
.input-error { border-color: #ef8083; background: #fffafa; }
.error-text { margin-top: 9rpx; color: #e45e61; font-size: 20rpx; }
.privacy-tip { margin-top: 11rpx; color: #9eafb7; font-size: 19rpx; }
.upload-field { margin-top: 34rpx; }
.upload-box { height: 260rpx; box-sizing: border-box; padding-top: 46rpx; border: 3rpx dashed #acd7e9; border-radius: 20rpx; background: #f5fbfe; text-align: center; }
.upload-icon { width: 68rpx; height: 68rpx; margin: 0 auto; border-radius: 50%; background: #dff3fb; color: #3199c7; font-size: 48rpx; font-weight: 300; line-height: 62rpx; }
.upload-title { margin-top: 19rpx; color: #39728d; font-size: 25rpx; font-weight: 600; }
.upload-desc { margin-top: 9rpx; color: #9aadb6; font-size: 20rpx; }
.uploaded-box { position: relative; height: 300rpx; overflow: hidden; border-radius: 20rpx; background: #edf4f7; }
.uploaded-image { width: 100%; height: 100%; }
.upload-success { position: absolute; top: 15rpx; left: 15rpx; padding: 8rpx 15rpx; border-radius: 18rpx; background: rgba(45, 174, 132, .9); color: #fff; font-size: 20rpx; }
.replace-button { position: absolute; right: 15rpx; bottom: 15rpx; padding: 10rpx 18rpx; border-radius: 20rpx; background: rgba(31, 66, 82, .72); color: #fff; font-size: 20rpx; }
.photo-tips { display: flex; justify-content: space-between; margin-top: 14rpx; color: #91a6b0; font-size: 18rpx; }
.photo-tips text { color: #48ae8b; }
.agreement { display: flex; align-items: flex-start; margin-top: 38rpx; color: #778e9a; font-size: 20rpx; line-height: 1.55; }
.checkbox { flex: none; width: 34rpx; height: 34rpx; margin: 0 13rpx 0 2rpx; box-sizing: border-box; border: 2rpx solid #b9cbd4; border-radius: 8rpx; color: #fff; font-size: 22rpx; line-height: 30rpx; text-align: center; }
.checkbox.checked { border-color: #3da5d4; background: #3da5d4; }
.primary-button { height: 92rpx; margin-top: 34rpx; border-radius: 46rpx; background: linear-gradient(90deg, #4bb2df, #278fc5); color: #fff; font-size: 28rpx; font-weight: 600; line-height: 92rpx; box-shadow: 0 12rpx 25rpx rgba(43, 149, 199, .2); }
.button-disabled { background: #cbdce4; color: #f6f9fa; box-shadow: none; }
.demo-note { margin-top: 18rpx; color: #a3b3ba; font-size: 19rpx; text-align: center; }

.result-card { padding: 55rpx 38rpx 38rpx; text-align: center; }
.result-icon { width: 104rpx; height: 104rpx; margin: 0 auto; border-radius: 50%; background: #e2f7ee; color: #2cad82; font-size: 58rpx; line-height: 104rpx; }
.result-title { margin-top: 25rpx; color: #284755; font-size: 35rpx; font-weight: 700; }
.result-desc { margin: 14rpx auto 0; max-width: 540rpx; color: #8298a3; font-size: 23rpx; line-height: 1.65; }
.identity-row { display: flex; justify-content: space-between; margin-top: 38rpx; padding: 25rpx; border-radius: 16rpx; background: #f2faf7; color: #78918a; font-size: 23rpx; }
.identity-value { color: #229b71; font-weight: 600; }
.text-button { margin-top: 14rpx; background: transparent; color: #7e9aa8; font-size: 22rpx; }
.loading-ring { width: 86rpx; height: 86rpx; margin: 5rpx auto 0; box-sizing: border-box; border: 8rpx solid #dceff7; border-top-color: #3ca5d4; border-radius: 50%; animation: spin 1s linear infinite; }
.review-tip { margin-top: 30rpx; padding: 20rpx; border-radius: 14rpx; background: #edf8fd; color: #4f8aa5; font-size: 21rpx; }
@keyframes spin { from { transform: rotate(0); } to { transform: rotate(360deg); } }

.compliance { margin: 28rpx 28rpx 10rpx; padding: 24rpx; border-radius: 18rpx; background: #eaf2f5; color: #748a94; font-size: 20rpx; line-height: 1.65; }
.compliance-title { margin-bottom: 8rpx; color: #557684; font-weight: 700; }
