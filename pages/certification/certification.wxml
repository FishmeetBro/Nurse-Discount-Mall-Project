<!-- 护士认证页：仅作前端原型，认证结果保存在本地缓存 -->
<view class="page safe-bottom">
  <view class="hero">
    <view class="hero-decoration decoration-one">+</view>
    <view class="hero-decoration decoration-two">+</view>
    <image class="cert-illustration" src="/assets/images/certification-nurse.jpg" mode="aspectFill" />
    <view class="hero-title">护士身份认证</view>
    <view class="hero-desc">完成认证，解锁护士合伙人专享价</view>
    <view class="step-row">
      <view class="step active"><text>1</text><view>提交资料</view></view>
      <view class="step-line {{status != 'unverified' ? 'active-line' : ''}}"></view>
      <view class="step {{status != 'unverified' ? 'active' : ''}}"><text>2</text><view>平台审核</view></view>
      <view class="step-line {{status == 'verified' ? 'active-line' : ''}}"></view>
      <view class="step {{status == 'verified' ? 'active' : ''}}"><text>3</text><view>认证完成</view></view>
    </view>
  </view>

  <!-- 已认证状态 -->
  <view wx:if="{{status == 'verified'}}" class="result-card verified-card">
    <view class="result-icon">✓</view>
    <view class="result-title">认证已通过</view>
    <view class="result-desc">护士合伙人权益已生效，首页商品将展示专属低价标签。</view>
    <view class="identity-row">
      <text>认证身份</text>
      <text class="identity-value">护士合伙人</text>
    </view>
    <button class="primary-button" bindtap="backHome">返回首页选购</button>
    <button class="text-button" bindtap="resetCertification">重置演示状态</button>
  </view>

  <!-- 审核中状态 -->
  <view wx:elif="{{status == 'reviewing'}}" class="result-card reviewing-card">
    <view class="loading-ring"></view>
    <view class="result-title">资料审核中</view>
    <view class="result-desc">演示审核将在短暂等待后自动通过，请不要关闭当前页面。</view>
    <view class="review-tip">预计审核时间：约 2 秒（Demo）</view>
  </view>

  <!-- 未认证：资料填写表单 -->
  <block wx:else>
    <view class="benefit-card">
      <view class="benefit-title">认证后可享</view>
      <view class="benefit-list">
        <view class="benefit-item"><view class="benefit-icon">¥</view><text>护士专享价</text></view>
        <view class="benefit-item"><view class="benefit-icon">券</view><text>新人优惠券</text></view>
        <view class="benefit-item"><view class="benefit-icon">享</view><text>推广合伙人</text></view>
      </view>
    </view>

    <view class="form-card">
      <view class="card-title">认证资料</view>
      <view class="card-subtitle">请确保资料清晰、真实，仅用于本次演示</view>

      <view class="field">
        <view class="field-label"><text class="required">*</text> 身份证号码</view>
        <view class="input-wrap {{idError ? 'input-error' : ''}}">
          <input value="{{idCard}}" maxlength="18" type="idcard" placeholder="请输入18位身份证号码" placeholder-class="placeholder" bindinput="onIdInput" bindblur="validateIdCard" />
          <text wx:if="{{idCard}}" class="clear" bindtap="clearIdCard">×</text>
        </view>
        <view wx:if="{{idError}}" class="error-text">{{idError}}</view>
        <view class="privacy-tip">身份证信息将进行脱敏展示与本地保存</view>
      </view>

      <view class="field upload-field">
        <view class="field-label"><text class="required">*</text> 护士执业证书</view>
        <view wx:if="{{certificateImage}}" class="uploaded-box">
          <image class="uploaded-image" src="{{certificateImage}}" mode="aspectFill" bindtap="previewCertificate" />
          <view class="upload-success"><text>✓</text> 已上传</view>
          <view class="replace-button" bindtap="chooseCertificate">重新上传</view>
        </view>
        <view wx:else class="upload-box" bindtap="chooseCertificate">
          <view class="upload-icon">＋</view>
          <view class="upload-title">上传护士证照片</view>
          <view class="upload-desc">请保证姓名、编号及执业信息清晰可见</view>
        </view>
        <view class="photo-tips">
          <view><text>✓</text> 支持相册选择或拍照</view>
          <view><text>✓</text> 图片大小不超过 10MB</view>
        </view>
      </view>

      <view class="agreement" bindtap="toggleAgreement">
        <view class="checkbox {{agreed ? 'checked' : ''}}">{{agreed ? '✓' : ''}}</view>
        <view>我已阅读并同意《认证服务说明》，承诺提交资料真实有效</view>
      </view>

      <button class="primary-button {{canSubmit ? '' : 'button-disabled'}}" disabled="{{!canSubmit}}" bindtap="submitReview">提交模拟审核</button>
      <view class="demo-note">Demo 提示：本页面不会上传任何资料到服务器</view>
    </view>
  </block>

  <compliance-notice title="认证合规提示">认证权益仅限本人合规使用。</compliance-notice>
</view>
