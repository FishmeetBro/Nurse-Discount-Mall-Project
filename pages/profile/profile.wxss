.page { min-height: 100vh; padding-bottom: 40rpx; background: #f5fafd; }
.profile-header { padding: 38rpx 28rpx 75rpx; background: linear-gradient(145deg, #49add8, #277fa9); }
.user-row { display: flex; align-items: center; color: #fff; }
.avatar { position: relative; width: 102rpx; height: 102rpx; border: 5rpx solid rgba(255,255,255,.7); border-radius: 50%; background: #edf9fe; color: #278bb5; font-size: 38rpx; font-weight: 700; text-align: center; line-height: 102rpx; }
.avatar-mark { position: absolute; right: -4rpx; bottom: 0; width: 31rpx; height: 31rpx; border: 3rpx solid #fff; border-radius: 50%; background: #32b087; color: #fff; font-size: 18rpx; line-height: 31rpx; }
.user-info { flex: 1; margin-left: 20rpx; }
.user-name { font-size: 34rpx; font-weight: 700; }
.user-name text { margin-left: 8rpx; padding: 5rpx 10rpx; border-radius: 8rpx; background: rgba(255,255,255,.2); font-size: 17rpx; font-weight: 400; }
.user-id { margin-top: 10rpx; font-size: 20rpx; opacity: .76; }
.setting { width: 58rpx; font-size: 35rpx; text-align: center; }
.certification-bar { margin-top: 30rpx; padding: 20rpx 22rpx; display: flex; align-items: center; border: 2rpx solid rgba(255,255,255,.17); border-radius: 18rpx; background: rgba(255,255,255,.14); color: #fff; }
.cert-icon { width: 54rpx; height: 54rpx; border-radius: 16rpx; background: rgba(255,255,255,.2); font-size: 27rpx; font-weight: 700; text-align: center; line-height: 54rpx; }
.cert-main { flex: 1; margin-left: 15rpx; font-size: 24rpx; }
.cert-main text { display: block; margin-top: 4rpx; font-size: 18rpx; opacity: .75; }
.cert-action { font-size: 20rpx; }
.asset-card { position: relative; margin: -45rpx 28rpx 0; padding: 25rpx 5rpx; display: flex; border-radius: 24rpx; background: #fff; box-shadow: 0 10rpx 30rpx rgba(44,91,113,.09); }
.asset-item { flex: 1; text-align: center; }
.asset-item + .asset-item { border-left: 2rpx solid #eef2f4; }
.asset-item text, .asset-item view { display: block; }
.asset-item .asset-value { color: #294d5e; font-size: 32rpx; font-weight: 700; }
.asset-item .asset-label { margin-top: 5rpx; color: #617985; font-size: 21rpx; }
.asset-item view { margin-top: 5rpx; color: #a2b0b7; font-size: 16rpx; }
.card { margin: 22rpx 28rpx 0; padding: 28rpx; border-radius: 23rpx; background: #fff; box-shadow: 0 8rpx 27rpx rgba(45,91,113,.06); }
.section-head { display: flex; align-items: center; justify-content: space-between; }
.section-title { color: #294755; font-size: 29rpx; font-weight: 700; }
.section-more { color: #7e9aa8; font-size: 20rpx; }
.order-status-row { display: flex; justify-content: space-between; margin-top: 28rpx; }
.order-status-row > view { width: 23%; color: #667d89; font-size: 20rpx; text-align: center; }
.status-icon { position: relative; width: 61rpx; height: 61rpx; margin: 0 auto 10rpx; border-radius: 19rpx; background: #e8f6fc; color: #348fb8; font-size: 28rpx; line-height: 61rpx; }
.status-icon text { position: absolute; top: -10rpx; right: -9rpx; min-width: 29rpx; height: 29rpx; border-radius: 15rpx; background: #f06b6e; color: #fff; font-size: 17rpx; line-height: 29rpx; }
.order-list { margin: 0 28rpx; }
.order-item { margin-top: 20rpx; padding: 24rpx; border-radius: 21rpx; background: #fff; box-shadow: 0 7rpx 24rpx rgba(45,91,113,.06); }
.order-head { padding-bottom: 18rpx; display: flex; justify-content: space-between; border-bottom: 2rpx solid #f1f4f5; color: #91a3ac; font-size: 19rpx; }
.order-state { color: #e7854e; }
.order-product { padding: 20rpx 0; display: flex; align-items: center; }
.product-image { width: 108rpx; height: 108rpx; border-radius: 17rpx; color: #5d9fbc; font-size: 49rpx; text-align: center; line-height: 108rpx; }
.product-info { flex: 1; min-width: 0; margin-left: 17rpx; color: #385462; font-size: 23rpx; }
.product-info text { display: block; margin-top: 10rpx; color: #9aabb3; font-size: 18rpx; }
.order-price { color: #395461; font-size: 22rpx; text-align: right; }
.order-price text { color: #9daab1; font-size: 18rpx; }
.order-total { color: #7b8f99; font-size: 20rpx; text-align: right; }
.order-total text { color: #e75f63; font-size: 24rpx; font-weight: 700; }
.order-actions { display: flex; justify-content: flex-end; gap: 14rpx; margin-top: 19rpx; }
.order-actions button { width: 150rpx; height: 58rpx; margin: 0; padding: 0; border: 2rpx solid #c9d7dd; border-radius: 29rpx; background: #fff; color: #68818d; font-size: 20rpx; line-height: 56rpx; }
.order-actions button.primary { border-color: #3aa0cc; color: #328eb7; }
.empty-order { margin-top:20rpx;padding:30rpx;border-radius:20rpx;background:#fff;color:#9babb3;font-size:22rpx;text-align:center}.empty-order image{width:230rpx;height:180rpx;display:block;margin:0 auto 8rpx}
.performance-card { margin: 22rpx 28rpx 0; padding: 28rpx; border-radius: 24rpx; background: linear-gradient(145deg, #327f9f, #225e79); color: #fff; box-shadow: 0 12rpx 30rpx rgba(35,96,122,.18); }
.performance-head { display: flex; justify-content: space-between; align-items: center; }
.performance-title { font-size: 30rpx; font-weight: 700; }
.performance-head text { display: block; margin-top: 6rpx; font-size: 18rpx; opacity: .65; }
.performance-head > view:last-child { font-size: 19rpx; opacity: .8; }
.performance-grid { display: flex; margin-top: 28rpx; padding: 23rpx 0; border-top: 2rpx solid rgba(255,255,255,.13); border-bottom: 2rpx solid rgba(255,255,255,.13); }
.performance-grid > view { flex: 1; text-align: center; }
.performance-grid > view + view { border-left: 2rpx solid rgba(255,255,255,.13); }
.performance-grid > view > text { display: block; font-size: 17rpx; opacity: .7; }
.performance-grid .performance-value { margin-top: 8rpx; font-size: 28rpx; font-weight: 700; opacity: 1; }
.performance-value text { margin: 0 3rpx; font-size: 16rpx; font-weight: 400; }
.performance-grid > view > view { margin-top: 7rpx; color: #83e0c4; font-size: 16rpx; }
.trend { margin-top: 25rpx; }
.trend-title { font-size: 20rpx; }
.trend-title text { float: right; font-size: 16rpx; opacity: .58; }
.chart { height: 175rpx; margin-top: 17rpx; display: flex; align-items: flex-end; justify-content: space-around; }
.bar-column { width: 13%; height: 100%; display: flex; flex-direction: column; align-items: center; }
.bar-value { height: 28rpx; font-size: 15rpx; opacity: .7; }
.bar-track { flex: 1; width: 22rpx; display: flex; align-items: flex-end; }
.bar { width: 100%; min-height: 6rpx; border-radius: 8rpx 8rpx 0 0; background: linear-gradient(#74d9c5, #45b5ce); }
.bar-column > text { margin-top: 7rpx; font-size: 16rpx; opacity: .65; }
.service-grid { display: flex; justify-content: space-between; margin-top: 28rpx; }
.service-grid > view { width: 23%; color: #637b87; font-size: 20rpx; text-align: center; }
.service-grid > view > view { width: 66rpx; height: 66rpx; margin: 0 auto 11rpx; border-radius: 19rpx; color: #3c89a8; font-size: 27rpx; font-weight: 600; line-height: 66rpx; }
.compliance { margin: 22rpx 28rpx 10rpx; padding: 24rpx; border-radius: 18rpx; background: #eaf2f5; color: #748a94; font-size: 20rpx; line-height: 1.65; }
.compliance-title { margin-bottom: 8rpx; color: #557684; font-weight: 700; }
