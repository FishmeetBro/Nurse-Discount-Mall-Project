.page{min-height:100vh;padding:24rpx 28rpx 40rpx;background:#f5fafd}.summary{padding:28rpx 12rpx;display:flex;border-radius:24rpx;background:linear-gradient(135deg,#2999c9,#227da8);color:#fff;box-shadow:0 12rpx 30rpx rgba(36,128,168,.18)}.summary>view{flex:1;text-align:center}.summary>view+view{border-left:1rpx solid rgba(255,255,255,.2)}.summary text{display:block;font-size:34rpx;font-weight:700}.summary view view{margin-top:7rpx;font-size:18rpx;opacity:.76}.tabs{margin-top:24rpx;padding:7rpx;display:flex;border-radius:20rpx;background:#e7f1f5}.tab{position:relative;flex:1;height:66rpx;border-radius:16rpx;color:#738b97;font-size:23rpx;text-align:center;line-height:66rpx;transition:all .2s ease}.tab.active{background:#fff;color:#268dbb;font-weight:600;box-shadow:0 5rpx 16rpx rgba(42,95,119,.09)}.list{margin-top:22rpx}.coupon{position:relative;min-height:186rpx;margin-top:18rpx;padding:22rpx 20rpx;display:flex;align-items:center;overflow:hidden;border:1rpx solid #e5eef2;border-radius:22rpx;background:#fff;box-shadow:0 8rpx 24rpx rgba(42,91,114,.07)}.coupon::before,.coupon::after{content:"";position:absolute;left:184rpx;width:25rpx;height:25rpx;border-radius:50%;background:#f5fafd}.coupon::before{top:-13rpx}.coupon::after{bottom:-13rpx}.amount{flex:none;width:165rpx;padding-right:20rpx;border-right:2rpx dashed #dbe7ec;color:#ec6265;text-align:center}.amount view{font-size:48rpx;font-weight:700}.amount view text{display:inline;font-size:22rpx}.amount>text{display:block;margin-top:3rpx;color:#8499a3;font-size:18rpx}.coupon-main{flex:1;min-width:0;margin-left:23rpx}.coupon-title{color:#345260;font-size:25rpx;font-weight:700}.coupon-title text{margin-left:6rpx;padding:4rpx 7rpx;border-radius:6rpx;background:#fff0e9;color:#ed744e;font-size:15rpx}.scope{margin-top:12rpx;color:#718994;font-size:19rpx}.expiry{margin-top:10rpx;color:#a0afb6;font-size:17rpx}.coupon button{flex:none;width:105rpx;height:55rpx;margin:0 0 0 12rpx;padding:0;border-radius:28rpx;background:#2d9ac7;color:#fff;font-size:19rpx;line-height:55rpx}.coupon button::after{border:0}.disabled{filter:grayscale(.65);opacity:.65}.status-text{width:90rpx;color:#8699a2;font-size:19rpx;text-align:center}.empty{padding:100rpx 0;color:#97a9b1;text-align:center}.empty view{width:90rpx;height:90rpx;margin:0 auto 20rpx;border-radius:50%;background:#e5f3f8;color:#5da6c3;font-size:35rpx;line-height:90rpx}
