.page{min-height:100vh;padding:24rpx 28rpx 40rpx;background:#f5fafd}.address-card{padding:27rpx 23rpx;display:flex;align-items:center;border-radius:22rpx;background:#fff;box-shadow:0 8rpx 24rpx rgba(43,89,111,.07)}.address-icon{flex:none;width:62rpx;height:62rpx;border-radius:18rpx;background:#e4f4fa;color:#2b91bb;font-size:30rpx;text-align:center;line-height:62rpx}.address{flex:1;margin-left:17rpx;color:#375461;font-size:24rpx;font-weight:600}.address text{display:block;margin-top:8rpx;color:#8298a2;font-size:19rpx;font-weight:400}.address-card>view:last-child{color:#8fa3ac;font-size:32rpx}.card{margin-top:20rpx;padding:26rpx 23rpx;border-radius:22rpx;background:#fff;box-shadow:0 8rpx 24rpx rgba(43,89,111,.06)}.card-title{color:#2f4e5c;font-size:27rpx;font-weight:700}.pay-item{padding:22rpx 0;display:flex;align-items:center;border-bottom:1rpx solid #edf2f4}.pay-item:last-child{border-bottom:0}.pay-item image{flex:none;width:112rpx;height:112rpx;border-radius:17rpx}.pay-item>view:nth-child(2){flex:1;min-width:0;margin-left:16rpx;color:#3b5764;font-size:22rpx}.pay-item>view:nth-child(2) text{display:block;margin-top:8rpx;color:#9aabb2;font-size:18rpx}.item-price{text-align:right}.item-price view{color:#e85e62;font-size:22rpx;font-weight:600}.item-price text{color:#9baab1;font-size:18rpx}.fee-card>view{padding:19rpx 0;display:flex;justify-content:space-between;border-bottom:1rpx solid #eef2f4;color:#66808c;font-size:22rpx}.fee-card>view:last-child{border-bottom:0}.fee-card>view>text:last-child{color:#405c68}.fee-card .discount{color:#e46a67}.fee-card .payable-row{padding-bottom:0;color:#294b5a;font-weight:700}.fee-card .payable-row text:last-child{color:#e75d62;font-size:29rpx}.bottom-placeholder{height:140rpx}.pay-bar{position:fixed;z-index:30;right:0;bottom:0;left:0;padding:14rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));display:flex;align-items:center;background:#fff;box-shadow:0 -8rpx 28rpx rgba(39,82,103,.1)}.pay-bar>view{flex:1;color:#6c838e;font-size:20rpx}.pay-bar strong{color:#e75d62;font-size:32rpx}.pay-bar button{width:220rpx;height:76rpx;margin:0;border-radius:38rpx;background:linear-gradient(90deg,#41acd8,#278fc1);color:#fff;font-size:24rpx;line-height:76rpx}.pay-bar button::after{border:0}
.pay-bar .pay-price{color:#e75d62;font-size:32rpx;font-weight:700}
