.page{min-height:100vh;padding:28rpx;background:#f5fafd}.cart-head{display:flex;align-items:center;justify-content:space-between}.title{color:#294755;font-size:34rpx;font-weight:700}.cart-head text{display:block;margin-top:7rpx;color:#8da1ab;font-size:19rpx}.edit{padding:10rpx 20rpx;border-radius:24rpx;background:#e4f3f9;color:#2c8db6;font-size:21rpx}.cart-list{margin-top:22rpx}.cart-item{position:relative;margin-top:18rpx;padding:22rpx 18rpx;display:flex;align-items:center;overflow:hidden;border:1rpx solid #e4eef2;border-radius:22rpx;background:#fff;box-shadow:0 8rpx 24rpx rgba(42,91,114,.06)}.checkbox{flex:none;width:38rpx;height:38rpx;border:2rpx solid #b9cbd3;border-radius:50%;color:#fff;font-size:22rpx;text-align:center;line-height:34rpx}.checkbox.checked{border-color:#2998c5;background:#2998c5}.product-image{flex:none;width:142rpx;height:142rpx;margin-left:16rpx;border-radius:18rpx;background:#edf7fb}.item-main{flex:1;min-width:0;margin-left:18rpx}.item-name{height:64rpx;overflow:hidden;color:#365360;font-size:24rpx;font-weight:600;line-height:32rpx}.item-feature{margin-top:6rpx;overflow:hidden;color:#98a8af;font-size:18rpx;white-space:nowrap;text-overflow:ellipsis}.item-bottom{display:flex;align-items:center;justify-content:space-between;margin-top:15rpx}.price{color:#eb5e62;font-size:31rpx;font-weight:700}.price text{font-size:19rpx}.stepper{height:48rpx;display:flex;align-items:center;border:1rpx solid #d8e4e9;border-radius:24rpx}.stepper button{width:47rpx;height:46rpx;margin:0;padding:0;background:transparent;color:#54717e;font-size:27rpx;line-height:43rpx}.stepper button::after{border:0}.stepper text{width:50rpx;color:#3e5966;font-size:20rpx;text-align:center}.delete{align-self:stretch;width:88rpx;margin:-22rpx -18rpx -22rpx 15rpx;display:flex;align-items:center;justify-content:center;background:#ef6c70;color:#fff;font-size:21rpx}.empty{padding:110rpx 0;color:#607b87;text-align:center}.empty image{width:310rpx;height:250rpx}.empty view{font-size:28rpx;font-weight:600}.empty text{display:block;margin-top:10rpx;color:#9babb2;font-size:20rpx}.empty button{width:190rpx;height:68rpx;margin-top:26rpx;border-radius:34rpx;background:#2e99c6;color:#fff;font-size:22rpx;line-height:68rpx}.empty button::after{border:0}.bottom-placeholder{height:150rpx}.settlement-bar{position:fixed;z-index:30;right:0;bottom:0;left:0;min-height:112rpx;padding:14rpx 24rpx calc(14rpx + env(safe-area-inset-bottom));display:flex;align-items:center;background:#fff;box-shadow:0 -8rpx 28rpx rgba(39,82,103,.1)}.select-all{display:flex;align-items:center;color:#647d88;font-size:21rpx}.select-all text{margin-left:10rpx}.total{flex:1;margin-left:22rpx}.total>text{color:#6f8792;font-size:19rpx}.total>view{display:inline;color:#e85e62;font-size:31rpx;font-weight:700}.total>view text{font-size:18rpx}.total small{display:block;margin-top:2rpx;color:#a1afb6;font-size:16rpx}.checkout,.delete-selected{width:190rpx;height:76rpx;margin:0;border-radius:38rpx;font-size:24rpx;line-height:76rpx}.checkout{background:linear-gradient(90deg,#40acd8,#278fc1);color:#fff}.delete-selected{margin-left:auto;border:1rpx solid #e57a7d;background:#fff;color:#df6266}.checkout::after,.delete-selected::after{border:0}
.total .selected-count{display:block;margin-top:2rpx;color:#a1afb6;font-size:16rpx}
