.product-card{overflow:hidden;background:#fff;border:1rpx solid #e8f1f5;border-radius:24rpx;box-shadow:0 10rpx 30rpx rgba(31,88,116,.08);transition:transform .18s ease,box-shadow .18s ease}.pressable:active{transform:scale(.98);box-shadow:0 5rpx 18rpx rgba(31,88,116,.1)}.image-wrap{position:relative;height:258rpx;overflow:hidden;background:#edf8fc}.image-wrap image{width:100%;height:100%}.badge,.quality{position:absolute;padding:7rpx 13rpx;border-radius:0 14rpx 14rpx 0;font-size:18rpx}.badge{top:15rpx;left:0;background:#ff756f;color:#fff}.quality{right:12rpx;bottom:12rpx;border-radius:12rpx;background:rgba(255,255,255,.9);color:#2488b6}.info{padding:20rpx}.name{height:70rpx;overflow:hidden;color:#243f4e;font-size:26rpx;font-weight:600;line-height:35rpx}.feature{margin-top:7rpx;overflow:hidden;color:#91a5af;font-size:19rpx;white-space:nowrap;text-overflow:ellipsis}.price-label{display:inline-block;margin-top:15rpx;padding:5rpx 10rpx;border-radius:8rpx;background:#e9f7fd;color:#278fbd;font-size:17rpx}.price-row{display:flex;align-items:baseline;margin-top:5rpx}.price{color:#ef5f63;font-size:38rpx;font-weight:700}.price text{font-size:21rpx}.origin{margin-left:10rpx;color:#a5b2b9;font-size:19rpx;text-decoration:line-through}.bottom{display:flex;align-items:center;justify-content:space-between;margin-top:6rpx;color:#a1b0b7;font-size:18rpx}.bottom button{width:48rpx;height:48rpx;margin:0;padding:0;border-radius:50%;background:#2999cd;color:#fff;font-size:31rpx;line-height:46rpx}.bottom button::after{border:0}
