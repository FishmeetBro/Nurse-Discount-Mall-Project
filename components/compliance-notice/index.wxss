.notice{margin:28rpx;padding:22rpx;display:flex;border:1rpx solid #dceaf0;border-radius:18rpx;background:#f1f7f9;color:#6f8792;font-size:20rpx;line-height:1.6}.notice.compact{margin:20rpx 0}.icon{flex:none;width:34rpx;height:34rpx;margin-right:13rpx;border-radius:50%;background:#d7edf5;color:#318caf;font-weight:700;text-align:center;line-height:34rpx}.content{flex:1}.title{color:#466c7c;font-weight:700}.text:empty{display:none}.default{margin-top:4rpx}.more{margin-top:9rpx;color:#278db8;font-weight:600}.pressable{transition:transform .18s ease,opacity .18s ease}.pressable:active{transform:scale(.98);opacity:.86}.mask{position:fixed;z-index:999;top:0;right:0;bottom:0;left:0;padding:0 46rpx;display:flex;align-items:center;justify-content:center;background:rgba(22,45,57,.62);animation:fade-in .2s ease}.dialog{width:100%;padding:38rpx 30rpx 30rpx;border-radius:28rpx;background:#fff;box-shadow:0 24rpx 70rpx rgba(18,55,72,.2);animation:dialog-in .24s ease}.dialog-icon{width:72rpx;height:72rpx;margin:0 auto;border-radius:50%;background:#e2f4fb;color:#258bb7;font-size:37rpx;font-weight:700;text-align:center;line-height:72rpx}.dialog-title{margin:18rpx 0 25rpx;color:#274755;font-size:30rpx;font-weight:700;text-align:center}.rule{padding:18rpx 0;display:flex;border-top:1rpx solid #edf2f4}.rule>text{flex:none;width:48rpx;color:#38a0ca;font-size:19rpx;font-weight:700}.rule>view{flex:1}.rule view view{color:#3d5967;font-size:23rpx;font-weight:600}.rule view text{display:block;margin-top:7rpx;color:#8297a1;font-size:19rpx;line-height:1.55}.confirm{height:78rpx;margin-top:24rpx;border-radius:39rpx;background:linear-gradient(90deg,#42acd8,#258cc0);color:#fff;font-size:25rpx;line-height:78rpx}.confirm::after{border:0}@keyframes fade-in{from{opacity:0}to{opacity:1}}@keyframes dialog-in{from{opacity:0;transform:translateY(20rpx) scale(.98)}to{opacity:1;transform:translateY(0) scale(1)}}
