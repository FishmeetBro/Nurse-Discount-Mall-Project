.order{margin-top:20rpx;padding:24rpx;border:1rpx solid #e8f0f3;border-radius:22rpx;background:#fff;box-shadow:0 8rpx 26rpx rgba(31,88,116,.06)}.head{padding-bottom:17rpx;display:flex;justify-content:space-between;border-bottom:1rpx solid #edf2f4;color:#91a3ac;font-size:19rpx}.state{color:#e47d47}.product{padding:20rpx 0;display:flex;align-items:center}.product image{flex:none;width:108rpx;height:108rpx;border-radius:17rpx;background:#edf7fb}.info{flex:1;min-width:0;margin-left:17rpx;color:#385462;font-size:23rpx}.info text{display:block;margin-top:9rpx;color:#9aabb3;font-size:18rpx}.price{color:#395461;font-size:22rpx;text-align:right}.price text{color:#9daab1;font-size:18rpx}.total{color:#7b8f99;font-size:20rpx;text-align:right}.total text{color:#e75f63;font-size:24rpx;font-weight:700}.actions{display:flex;justify-content:flex-end;gap:14rpx;margin-top:18rpx}.actions button{width:150rpx;height:58rpx;margin:0;padding:0;border:1rpx solid #c9d7dd;border-radius:29rpx;background:#fff;color:#68818d;font-size:20rpx;line-height:56rpx}.actions button::after{border:0}.actions .primary{border-color:#3aa0cc;color:#328eb7}
