<view class="order"><view class="head"><text>订单号 {{order.orderNo}}</text><text class="state">{{order.statusText}}</text></view><view class="product"><image src="{{order.image}}" mode="aspectFill" lazy-load/><view class="info"><view>{{order.name}}</view><text>{{order.spec}}</text></view><view class="price"><view>¥{{order.price}}</view><text>x{{order.quantity}}</text></view></view><view class="total">共{{order.quantity}}件　实付：<text>¥{{order.total}}</text></view><view class="actions"><button data-action="detail" bindtap="act">查看详情</button><button wx:if="{{order.status == 'unpaid'}}" class="primary" data-action="pay" bindtap="act">模拟支付</button><button wx:if="{{order.status == 'shipping'}}" class="primary" data-action="logistics" bindtap="act">模拟物流</button><button wx:if="{{order.status == 'finished'}}" class="primary" data-action="buyAgain" bindtap="act">再次购买</button></view></view>
